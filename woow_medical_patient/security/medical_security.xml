<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_medical" model="ir.module.category">
        <field name="name">Medical</field>
        <field name="description">Medical clinic management modules.</field>
        <field name="sequence">80</field>
    </record>

    <!-- Security Groups -->
    <record id="group_medical_user" model="res.groups">
        <field name="name">Medical User</field>
        <field name="comment">Basic medical staff (reception, nurses). Can read/create patients.</field>
        <field name="category_id" ref="module_category_medical"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_medical_physician" model="res.groups">
        <field name="name">Medical Physician</field>
        <field name="comment">Physicians. Can create and manage medical records.</field>
        <field name="category_id" ref="module_category_medical"/>
        <field name="implied_ids" eval="[(4, ref('group_medical_user'))]"/>
    </record>

    <record id="group_medical_admin" model="res.groups">
        <field name="name">Medical Administrator</field>
        <field name="comment">Full access to all medical data and configuration.</field>
        <field name="category_id" ref="module_category_medical"/>
        <field name="implied_ids" eval="[(4, ref('group_medical_physician'))]"/>
    </record>

    <record id="group_medical_pii" model="res.groups">
        <field name="name">Medical PII Access</field>
        <field name="comment">Independent group granting access to sensitive PII fields (national ID, NHI card).</field>
        <field name="category_id" ref="module_category_medical"/>
    </record>

    <!-- Multi-Company Record Rule: medical.patient -->
    <record id="medical_patient_comp_rule" model="ir.rule">
        <field name="name">Medical Patient: Multi-Company</field>
        <field name="model_id" ref="model_medical_patient"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids),
        ]</field>
        <field name="global" eval="True"/>
    </record>
</odoo>
