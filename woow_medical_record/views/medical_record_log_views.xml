<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Access Log: List View                                        -->
    <!-- ============================================================ -->
    <record id="medical_record_log_view_list" model="ir.ui.view">
        <field name="name">medical.record.access.log.list</field>
        <field name="model">medical.record.access.log</field>
        <field name="arch" type="xml">
            <list string="Access Logs" create="0" edit="0" delete="0">
                <field name="create_date" string="Timestamp"/>
                <field name="record_id"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Access Log: Search View                                      -->
    <!-- ============================================================ -->
    <record id="medical_record_log_view_search" model="ir.ui.view">
        <field name="name">medical.record.access.log.search</field>
        <field name="model">medical.record.access.log</field>
        <field name="arch" type="xml">
            <search string="Search Access Logs">
                <field name="record_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="filter_view" string="View"
                        domain="[('action', '=', 'view')]"/>
                <filter name="filter_sign" string="Sign"
                        domain="[('action', '=', 'sign')]"/>
                <filter name="filter_unsign" string="Unsign"
                        domain="[('action', '=', 'unsign')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="groupby_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="groupby_action" string="Action"
                            context="{'group_by': 'action'}"/>
                    <filter name="groupby_record" string="Record"
                            context="{'group_by': 'record_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Access Log: Action                                           -->
    <!-- ============================================================ -->
    <record id="medical_record_log_action" model="ir.actions.act_window">
        <field name="name">Access Logs</field>
        <field name="res_model">medical.record.access.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="medical_record_log_view_search"/>
    </record>

</odoo>
