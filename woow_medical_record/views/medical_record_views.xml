<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Form View (modeled after hr.expense.form)                    -->
    <!-- ============================================================ -->
    <record id="medical_record_view_form" model="ir.ui.view">
        <field name="name">medical.record.form</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <form string="Medical Record">
                <header>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_sign"
                            string="Sign"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'signed'"
                            groups="woow_medical_patient.group_medical_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,signed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_access_logs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list-alt"
                                groups="woow_medical_patient.group_medical_admin">
                            <field name="access_log_count"
                                   widget="statinfo"
                                   string="Access Logs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="New"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="physician_id"/>
                        </group>
                        <group>
                            <field name="visit_date"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab S: Subjective -->
                        <page string="Subjective (S)" name="subjective">
                            <field name="subjective" placeholder="Chief complaint and subjective symptoms..."/>
                        </page>

                        <!-- Tab O: Objective -->
                        <page string="Objective (O)" name="objective">
                            <group string="Vital Signs">
                                <group>
                                    <field name="vital_height"/>
                                    <field name="vital_weight"/>
                                    <field name="vital_temp"/>
                                </group>
                                <group>
                                    <field name="vital_bp_systolic"/>
                                    <field name="vital_bp_diastolic"/>
                                    <field name="vital_pulse"/>
                                </group>
                            </group>
                            <separator string="Objective Findings"/>
                            <field name="objective" placeholder="Objective findings and observations..."/>
                        </page>

                        <!-- Tab A: Assessment -->
                        <page string="Assessment (A)" name="assessment">
                            <group>
                                <field name="diagnosis" placeholder="Diagnosis..."/>
                            </group>
                            <separator string="Assessment Detail"/>
                            <field name="assessment" placeholder="Clinical assessment..."/>
                        </page>

                        <!-- Tab P: Plan -->
                        <page string="Plan (P)" name="plan">
                            <field name="plan" placeholder="Treatment plan and follow-up..."/>
                        </page>

                        <!-- Tab: Attachments -->
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- List / Tree View                                             -->
    <!-- ============================================================ -->
    <record id="medical_record_view_list" model="ir.ui.view">
        <field name="name">medical.record.list</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <list string="Medical Records"
                  default_order="visit_date desc, name desc"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'signed'">
                <field name="name"/>
                <field name="visit_date"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search View                                                  -->
    <!-- ============================================================ -->
    <record id="medical_record_view_search" model="ir.ui.view">
        <field name="name">medical.record.search</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <search string="Search Medical Records">
                <field name="name" string="Record No. / Patient / Diagnosis"
                       filter_domain="[
                           '|', '|',
                           ('name', 'ilike', self),
                           ('patient_id', 'ilike', self),
                           ('diagnosis', 'ilike', self),
                       ]"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <separator/>
                <filter name="filter_my_records" string="My Records"
                        domain="[('physician_id', '=', uid)]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('visit_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                 ('visit_date', '&lt;', datetime.datetime.combine(context_today() + relativedelta(days=1), datetime.time(0,0,0)))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('visit_date', '&gt;=', (context_today() - relativedelta(weekday=0, weeks=1)).strftime('%Y-%m-%d')),
                                 ('visit_date', '&lt;', (context_today() + relativedelta(weekday=0)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('visit_date', '&gt;=', context_today().strftime('%Y-%m-01')),
                                 ('visit_date', '&lt;', (context_today() + relativedelta(months=1)).strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_signed" string="Signed"
                        domain="[('state', '=', 'signed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="groupby_physician" string="Physician"
                            context="{'group_by': 'physician_id'}"/>
                    <filter name="groupby_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="groupby_visit_day" string="Visit Date (Day)"
                            context="{'group_by': 'visit_date:day'}"/>
                    <filter name="groupby_visit_week" string="Visit Date (Week)"
                            context="{'group_by': 'visit_date:week'}"/>
                    <filter name="groupby_visit_month" string="Visit Date (Month)"
                            context="{'group_by': 'visit_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Calendar View                                                -->
    <!-- ============================================================ -->
    <record id="medical_record_view_calendar" model="ir.ui.view">
        <field name="name">medical.record.calendar</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <calendar string="Medical Records"
                      date_start="visit_date"
                      color="physician_id"
                      quick_create="0">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
            </calendar>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Pivot View                                                   -->
    <!-- ============================================================ -->
    <record id="medical_record_view_pivot" model="ir.ui.view">
        <field name="name">medical.record.pivot</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <pivot string="Medical Records">
                <field name="physician_id" type="row"/>
                <field name="visit_date" interval="month" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Actions                                                      -->
    <!-- ============================================================ -->
    <record id="medical_record_action" model="ir.actions.act_window">
        <field name="name">Medical Records</field>
        <field name="res_model">medical.record</field>
        <field name="view_mode">list,form,calendar,pivot</field>
        <field name="search_view_id" ref="medical_record_view_search"/>
        <field name="context">{'medical_form_view': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first medical record
            </p>
            <p>
                Record patient visits using the SOAP documentation method.
            </p>
        </field>
    </record>

    <record id="medical_record_action_my" model="ir.actions.act_window">
        <field name="name">My Records</field>
        <field name="res_model">medical.record</field>
        <field name="view_mode">list,form,calendar,pivot</field>
        <field name="search_view_id" ref="medical_record_view_search"/>
        <field name="context">{'medical_form_view': True, 'search_default_filter_my_records': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No records yet
            </p>
            <p>
                Medical records where you are the physician will appear here.
            </p>
        </field>
    </record>

</odoo>
