<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Medical Record Sequence: YYYYMMDD-001, daily reset via date range -->
    <record id="seq_medical_record" model="ir.sequence">
        <field name="name">Medical Record</field>
        <field name="code">medical.record</field>
        <field name="prefix">%(range_year)s%(range_month)s%(range_day)s-</field>
        <field name="padding">3</field>
        <field name="implementation">no_gap</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
